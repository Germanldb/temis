---
import ChatIsla from "../components/ChatIsla.jsx";
import "../styles/global.css";
import { supabase } from "../db/supabase";
const { data, error } = await supabase.from("todos").select("*");
// Project Temis: Asistente Juridico IA
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Temis: Tu Asistente Jurídico IA</title>
        <meta
            name="description"
            content="Temis es un asistente jurídico inteligente basado en Gemini 1.5 Flash para consultas legales rápidas y precisas."
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="bg-[#1e1e1e] text-[#f0f0f0] font-['Outfit',sans-serif] min-h-screen"
    >
        {/* Navigation */}
        <nav class="flex items-center justify-between p-6 max-w-6xl mx-auto">
            <div class="flex items-center gap-3">
                <span class="text-3xl">⚖️</span>
                <span
                    class="text-xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#5c120e] via-[#921E16] to-[#c43a30]"
                    >Temis</span
                >
            </div>
            <div
                class="flex gap-6 items-center text-sm font-medium text-[#f0f0f0]/70"
            >
                <a href="/leyes" class="hover:text-[#efb810] transition-all"
                    >Leyes</a
                >
                <a href="/biblioteca" class="hover:text-[#efb810] transition-all"
                    >Biblioteca</a
                >
                <div class="h-4 w-px bg-[#f0f0f0]/20"></div>
                <a
                    href="/login"
                    id="loginBtn"
                    class="px-5 py-2 bg-[#921E16] hover:bg-[#921E16]/80 text-[#f0f0f0] rounded-full transition-all border border-[#921E16]/50"
                    >Ingresar</a
                >
            </div>
        </nav>

        {/* Hero & Main Content */}
        <main
            class="max-w-6xl mx-auto px-6 pt-12 pb-24 grid lg:grid-cols-2 gap-16 items-center overflow-hidden"
        >
            {/* Text Content */}
            <div class="space-y-8">
                <div
                    class="inline-flex items-center gap-2 px-4 py-2 bg-[#921E16]/10 border border-[#921E16]/30 text-[#efb810] text-xs font-bold uppercase tracking-[2px] rounded-full"
                >
                    <span class="w-2 h-2 bg-[#efb810] rounded-full animate-pulse"
                    ></span>
                    Acceso Legal para Todos
                </div>

                <h1 class="text-5xl lg:text-7xl font-bold leading-tight text-[#f0f0f0]">
                    La Justicia <br />
                    <span
                        class="text-transparent bg-clip-text bg-gradient-to-r from-[#c4940a] via-[#efb810] to-[#f7d86a]"
                        >al Alcance</span
                    >
                    <br />
                    de un Chat.
                </h1>

                <p
                    class="text-lg text-[#f0f0f0]/70 max-w-lg leading-relaxed font-light"
                >
                    Consulta leyes, verifica normativas y resuelve tus dudas
                    legales con la potencia de la Inteligencia Artificial
                    especializada. Rápido, preciso y siempre disponible.
                </p>

                <div class="flex flex-wrap gap-4 pt-4">
                    <div
                        class="flex items-center gap-4 bg-[#f0f0f0]/5 border border-[#f0f0f0]/10 p-4 rounded-2xl w-full sm:w-auto"
                    >
                        <div
                            class="w-10 h-10 bg-[#efb810]/20 rounded-xl flex items-center justify-center"
                        >
                            💡
                        </div>
                        <div class="text-sm">
                            <p class="font-bold text-[#f0f0f0]">Gemini 1.5 Flash</p>
                            <p class="text-xs text-[#f0f0f0]/50">
                                Costo-eficiente y rápido
                            </p>
                        </div>
                    </div>
                    <div
                        class="flex items-center gap-4 bg-[#f0f0f0]/5 border border-[#f0f0f0]/10 p-4 rounded-2xl w-full sm:w-auto"
                    >
                        <div
                            class="w-10 h-10 bg-[#921E16]/20 rounded-xl flex items-center justify-center"
                        >
                            🇻🇪
                        </div>
                        <div class="text-sm">
                            <p class="font-bold text-[#f0f0f0]">Pago Móvil</p>
                            <p class="text-xs text-[#f0f0f0]/50">
                                Activación inmediata
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            {/* Chat Isla Container */}
            <div class="relative">
                {/* Background Decor */}
                <div
                    class="absolute -top-24 -right-24 w-64 h-64 bg-[#921E16]/30 blur-[120px] rounded-full -z-10 animate-pulse"
                >
                </div>
                <div
                    class="absolute -bottom-24 -left-24 w-64 h-64 bg-[#efb810]/20 blur-[120px] rounded-full -z-10 animate-pulse"
                    style="animation-delay: 2s;"
                >
                </div>

                <div
                    class="w-full relative shadow-[0_0_100px_-20px_rgba(146,30,22,0.3)] rounded-[32px]"
                >
                    <ChatIsla client:load />
                </div>
            </div>
        </main>

        {/* Footer */}
        <footer class="border-t border-[#f0f0f0]/10 py-12 px-6 mt-12">
            <div
                class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8"
            >
                <div class="text-[#f0f0f0]/50 text-sm">
                    © 2026 Proyecto Temis. Todos los derechos reservados.
                </div>
                <div
                    class="flex items-center gap-8 text-[#f0f0f0]/50 text-sm font-medium"
                >
                    <a href="#" class="hover:text-[#efb810] transition-all"
                        >Términos</a
                    >
                    <a href="#" class="hover:text-[#efb810] transition-all"
                        >Privacidad</a
                    >
                    <a href="#" class="hover:text-[#efb810] transition-all"
                        >Contacto</a
                    >
                </div>
            </div>
        </footer>
        <script>
            // Simple check for demo purposes
            const loginBtn = document.getElementById('loginBtn');
            if (localStorage.getItem('temis_admin_logged') === 'true') {
                if (loginBtn) {
                    loginBtn.textContent = 'Panel Chat';
                    loginBtn.href = '/chat';
                    loginBtn.classList.remove('bg-[#921E16]');
                    loginBtn.classList.add('bg-[#efb810]', 'text-[#1e1e1e]', 'font-bold');
                }
            }
        </script>
    </body>
</html>
